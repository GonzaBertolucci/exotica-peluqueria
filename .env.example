# Supabase (crear en https://supabase.com)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key

# Meta WhatsApp Cloud API (crear en https://developers.facebook.com)
META_ACCESS_TOKEN=tu-access-token
META_PHONE_NUMBER_ID=tu-phone-id

# NextAuth (generar con: openssl rand -base64 32)
AUTH_SECRET=tu-secret
AUTH_URL=http://localhost:3000
